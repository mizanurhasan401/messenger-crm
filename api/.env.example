# ============================================================
# APPLICATION
# ============================================================
NODE_ENV=development
PORT=3000
APP_NAME="Messenger CRM SaaS"
API_PREFIX=api
API_VERSION=v1
SWAGGER_ENABLED=true
SWAGGER_PATH=docs
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
DATABASE_URL="postgresql://crm:crm_password@localhost:5432/crm_db?schema=public"

# ============================================================
# REDIS (Cache + BullMQ Queue)
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
CACHE_TTL_SECONDS=60

# ============================================================
# JWT AUTH
# ============================================================
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=messenger-crm
JWT_AUDIENCE=messenger-crm-clients

# ============================================================
# PASSWORD / SECURITY
# ============================================================
ARGON_MEMORY_COST=19456
ARGON_TIME_COST=2
ARGON_PARALLELISM=1
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120
THROTTLE_AUTH_MAX=10

# ============================================================
# EMAIL (verification / reset) — SMTP
# ============================================================
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="CRM <no-reply@crm.app>"
FRONTEND_URL=http://localhost:5173

# ============================================================
# CLOUDFLARE R2 (S3-compatible storage)
# ============================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=crm-uploads
R2_PUBLIC_URL=https://cdn.example.com
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_SIGNED_URL_TTL=900

# ============================================================
# EXTENSION API
# ============================================================
EXTENSION_API_KEY_HEADER=x-extension-key
