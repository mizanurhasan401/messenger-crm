# ─────────────────────────────────────────────────────────────
# Database (Postgres) — used by packages/database + backend
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://crm:crm@localhost:5432/messenger_crm?schema=public"

# ─────────────────────────────────────────────────────────────
# Redis — used by backend (BullMQ + cache)
# ─────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─────────────────────────────────────────────────────────────
# Auth (Better Auth) — backend
# ─────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET="change-me-with-a-long-random-string"
BETTER_AUTH_URL="http://localhost:4000"
# Comma-separated list of trusted client origins (dashboard + extension id)
AUTH_TRUSTED_ORIGINS="http://localhost:3000,chrome-extension://__EXTENSION_ID__"

# ─────────────────────────────────────────────────────────────
# Backend service
# ─────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
# CORS allowed origins (dashboard + extension)
CORS_ORIGINS="http://localhost:3000,chrome-extension://__EXTENSION_ID__"

# ─────────────────────────────────────────────────────────────
# Dashboard (Next.js) — public env must be NEXT_PUBLIC_*
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ─────────────────────────────────────────────────────────────
# Extension
# ─────────────────────────────────────────────────────────────
VITE_API_URL="http://localhost:4000"

# ─────────────────────────────────────────────────────────────
# Email (transactional — verification / reset / invites)
# ─────────────────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="CRM <no-reply@example.com>"

# ─────────────────────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────────────────────
SENTRY_DSN=""

# ─────────────────────────────────────────────────────────────
# Billing (Phase 7 — provider-agnostic, default Stripe)
# ─────────────────────────────────────────────────────────────
BILLING_PROVIDER="stripe"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
