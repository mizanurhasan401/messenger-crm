// Messenger CRM — Prisma schema (multi-tenant)
//
// Tenancy rule: every business table carries `organizationId` and is filtered
// by it in the backend via the TenantPrismaService $extends layer. The models
// listed as "global" (User, Organization, Session, Account, Verification) are
// intentionally NOT org-scoped and are excluded from that injection.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums  (canonical copies live in @messenger/shared; a CI test
// asserts the two stay identical — see packages/shared/src/enums.ts)
// ─────────────────────────────────────────────────────────────

enum Role {
  OWNER
  MANAGER
  AGENT
  VIEWER
}

enum MemberStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  RETURNED
  CANCELLED
}

enum FollowupStatus {
  PENDING
  COMPLETED
  CANCELLED
  SNOOZED
}

enum NotableType {
  CUSTOMER
  ORDER
  INTERNAL
}

enum NotificationType {
  FOLLOWUP_DUE
  ORDER_STATUS
  TEAM_INVITE
  SYSTEM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum SubscriptionPlan {
  FREE
  PRO
  BUSINESS
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  IMPORT
  EXPORT
  LOGIN
}

// ─────────────────────────────────────────────────────────────
// Global / auth models (NOT org-scoped) — Better Auth compatible
// ─────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships   OrganizationMember[]
  ownedOrgs     Organization[]       @relation("OrgOwner")
  sessions      Session[]
  accounts      Account[]
  notifications Notification[]

  @@map("users")
}

// Better Auth credential/oauth storage
model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("accounts")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

// ─────────────────────────────────────────────────────────────
// Tenancy root
// ─────────────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  ownerUserId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner        User                 @relation("OrgOwner", fields: [ownerUserId], references: [id])
  members      OrganizationMember[]
  roles        OrgRole[]
  customers    Customer[]
  customerTags CustomerTag[]
  orders       Order[]
  orderTimeline OrderTimeline[]
  notes        Note[]
  followups    Followup[]
  quickReplies QuickReply[]
  auditLogs    AuditLog[]
  activityLogs ActivityLog[]
  subscription Subscription?
  notifications Notification[]

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           Role         @default(AGENT)
  status         MemberStatus @default(INVITED)
  invitedBy      String?
  joinedAt       DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@map("organization_members")
}

// Optional custom role definitions per org (default roles are enforced via the Role enum).
model OrgRole {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  permissions    Json
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@map("roles")
}

// ─────────────────────────────────────────────────────────────
// CRM domain (all org-scoped)
// ─────────────────────────────────────────────────────────────

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  fbName         String?
  fbProfileUrl   String?
  name           String
  phone          String?
  email          String?
  address        Json?
  source         String?  @default("manual")
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tags         CustomerTag[]
  orders       Order[]
  notes        Note[]
  followups    Followup[]

  @@index([organizationId])
  @@index([organizationId, phone])
  @@index([organizationId, fbProfileUrl])
  @@map("customers")
}

model CustomerTag {
  id             String   @id @default(cuid())
  organizationId String
  customerId     String
  label          String
  color          String?  @default("#888888")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, label])
  @@index([organizationId])
  @@map("customer_tags")
}

model Order {
  id             String      @id @default(cuid())
  organizationId String
  customerId     String
  orderNumber    String
  status         OrderStatus @default(PENDING)
  items          Json        @default("[]")
  subtotal       Decimal     @default(0) @db.Decimal(12, 2)
  shippingFee    Decimal     @default(0) @db.Decimal(12, 2)
  total          Decimal     @default(0) @db.Decimal(12, 2)
  currency       String      @default("BDT")
  createdBy      String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  timeline     OrderTimeline[]
  notes        Note[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId, status])
  @@index([organizationId, customerId])
  @@map("orders")
}

model OrderTimeline {
  id             String       @id @default(cuid())
  organizationId String
  orderId        String
  fromStatus     OrderStatus?
  toStatus       OrderStatus
  changedBy      String
  note           String?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([organizationId, orderId])
  @@map("order_timeline")
}

model Note {
  id             String      @id @default(cuid())
  organizationId String
  notableType    NotableType
  customerId     String?
  orderId        String?
  body           String
  isInternal     Boolean     @default(false)
  createdBy      String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order        Order?       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([organizationId, customerId])
  @@index([organizationId, orderId])
  @@map("notes")
}

model Followup {
  id             String         @id @default(cuid())
  organizationId String
  customerId     String
  assignedTo     String
  dueAt          DateTime
  status         FollowupStatus @default(PENDING)
  reminderJobId  String?
  note           String?
  completedAt    DateTime?
  createdBy      String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId, dueAt, status])
  @@index([organizationId, assignedTo])
  @@map("followups")
}

model QuickReply {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  shortcut       String
  content        String
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, shortcut])
  @@index([organizationId])
  @@map("quick_replies")
}

// ─────────────────────────────────────────────────────────────
// Observability / platform
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id             String      @id @default(cuid())
  organizationId String
  actorUserId    String
  action         AuditAction
  entityType     String
  entityId       String?
  diff           Json?
  ipAddress      String?
  createdAt      DateTime    @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, entityType])
  @@map("audit_logs")
}

model ActivityLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  type           String
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@map("activity_logs")
}

model Subscription {
  id                 String             @id @default(cuid())
  organizationId     String             @unique
  plan               SubscriptionPlan   @default(FREE)
  status             SubscriptionStatus @default(TRIALING)
  providerCustomerId String?
  providerSubId      String?
  seats              Int                @default(1)
  currentPeriodEnd   DateTime?
  trialEndsAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  type           NotificationType
  title          String
  body           String?
  data           Json?
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([organizationId])
  @@map("notifications")
}
